# Neon DIRECT connection string (ensure "Pooled connection" is UNCHECKED in the Neon dashboard).
# Must end with ?sslmode=require
DATABASE_URL=balabalagehu
PORT=3000
RUST_LOG=info

# Set to true in production/HTTPS
COOKIE_SECURE=false

# "lax" for local testing, "none" for cross-site frontend (requires HTTPS/Secure=true)
COOKIE_SAMESITE=lax

# --- Later Phase Variables (Placeholders) ---
# SESSION_SECRET=
HF_SPACE_BASE=balabalagehu

GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URL=http://localhost:3000/auth/google/callback

# Set to the teammate's deployed frontend domain in prod (comma-separated for multiple origins)
FRONTEND_ORIGIN=http://localhost:3000,http://localhost:3001

RESEND_API_KEY=re_your_api_key_here
# SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS are no longer required for the Resend HTTP API
EMAIL_FROM="Cardiotox <onboarding@resend.dev>"
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
